{
  "name": "ninja-bot",
  "version": "1.0.0",
  "description": "Ninja Bot - Telegram Auto-Reply Native Windows App",
  "main": "dist/main.js",
  "scripts": {
    "build:js": "esbuild main.js --bundle --platform=node --outfile=dist/main.js --external:electron --external:electron:*",
    "start": "npm run build:js && electron .",
    "build": "npm run build:js && electron-builder --win --x64",
    "build-portable": "npm run build:js && electron-builder --win portable"
  },
  "author": "Ninja Bot",
  "license": "MIT",
  "dependencies": {
    "telegram": "^2.26.16",
    "input": "^1.0.1",
    "@mistralai/mistralai": "^0.5.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.20.0"
  },
  "build": {
    "appId": "com.ninja.bot",
    "productName": "Ninja Bot",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/main.js",
      "preload.js",
      "index.html",
      "icon.ico"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.ico"
    },
    "portable": {
      "artifactName": "NinjaBot.exe"
    }
  }
}
